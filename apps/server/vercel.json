{
  "version": 2,
  "functions": {
    "src/index.ts": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-payout",
      "schedule": "1 0 * * *"
    },
    {
      "path": "/api/cron/line-health-check",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/system-health",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/job-reminders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/overdue-jobs",
      "schedule": "*/5 * * * *"
    }
  ]
}