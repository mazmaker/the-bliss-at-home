{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node@3.0.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-payout",
      "schedule": "1 0 * * *"
    },
    {
      "path": "/api/cron/line-health-check",
      "schedule": "*/30 * * * *"
    }
  ]
}